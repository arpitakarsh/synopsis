# ContractScan AI — ai-service/.env
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# The service supports either of the following environment variable names;
# `GEMINI_API_KEY` is the original name used during the hackathon, while the
# more generic `OPENAI_API_KEY` matches the official OpenAI SDK examples. If
# both are present, `GEMINI_API_KEY` is preferred.
OPENAI_API_KEY="sk-proj-...your-key-here..."
# GEMINI_API_KEY="sk-proj-...your-key-here..."  # optional alternative

MODEL="gpt-4o"
MAX_TOKENS=4000
PORT=8001
